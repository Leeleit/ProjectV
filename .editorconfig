# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Indentation for C/C++ files (align with .clang-format)
[*.{c,h,cpp,hpp,cc,hh,cxx,hxx}]
indent_style = tab    # As per your .clang-format
indent_size = 4
tab_width = 4

# CMake
[CMakeLists.txt]
indent_style = space
indent_size = 4

# Makefiles always use tabs
[Makefile]
indent_style = tab

# Web files (if any tools/UI)
[*.{json,yml,yaml,md,xml}]
indent_style = space
indent_size = 2
