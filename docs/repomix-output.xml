#include <tracy/Tracy.hpp>

void render_text_profiled(FT_Face face, const char* text) {
    ZoneScoped;

    FT_Pos pen_x = 0;

    for (const char* p = text; *p; p++) {
        FT_UInt glyph_index;
        {
            ZoneScopedN("FT_Get_Char_Index");
            glyph_index = FT_Get_Char_Index(face, *p);
