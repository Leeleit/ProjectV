    static constexpr JPH::ObjectLayer DEBRIS = 4;       // Обломки
    static constexpr JPH::ObjectLayer NUM_LAYERS = 5;

    // BroadPhase Layers
    static constexpr JPH::BroadPhaseLayer BP_TERRAIN(0);
