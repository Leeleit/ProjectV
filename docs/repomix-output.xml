        if (isAudible(pos)) {
            m_placePool.play();
        }
    }

    void playStep(const glm::vec3& pos) {
        if (isAudible(pos)) {
            m_stepPool.play();
        }
    }

    void playBreak(const glm::vec3& pos) {
        if (isAudible(pos)) {
            m_breakPool.play();
        }
    }

