    ImGui::Text("FPS: %.1f", m_fps);
    ImGui::Text("Frame: %.2fms", m_frameTime);

    // Вложенные UI зоны
    {
        ZoneScopedNC("ImGui_DebugWindow", 0xFF00FF);
        renderDebugWindow();
    }

    {
        ZoneScopedNC("ImGui_Console", 0xFF00FF);
        renderConsole();
    }

    ImGui::End();

    // Финальный рендер ImGui
    {
