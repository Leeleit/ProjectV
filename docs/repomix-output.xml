}

// Создание loop-ambient
flecs::entity createAmbient(flecs::world& ecs, const char* path,
                            const glm::vec3& pos, float radius = 20.0f) {
    auto e = ecs.entity()
        .set<AudioEmitter>({
            .soundPath = path,
            .volume = 0.3f,
            .minDistance = 1.0f,
            .maxDistance = radius,
            .loop = true,
            .is3D = true,
            .autoPlay = true
        })
        .set<AudioInstance>({})
        .set<Position>({ pos.x, pos.y, pos.z })
        .add<Ambient>();

    return e;
}
```

