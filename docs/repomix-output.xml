        world.system<MeshletGeometry, const StaticMesh>("CreateMeshlets")
            .kind(flecs::OnLoad)
            .each([this](flecs::entity e, MeshletGeometry& meshlet, const StaticMesh& mesh) {
                if (meshlet.meshlet_count == 0 && mesh.index_count > 0) {
                    generateMeshlets(e, mesh);
                }
            });
    }

