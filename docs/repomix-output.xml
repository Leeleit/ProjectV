settings.mFixedPoint2 = JPH::RVec3(2, 5, 0);

// Длина троса
settings.mRatio = 1.0f;  // Отношение длин

JPH::Constraint* constraint = settings.Create(body1, body2);
physics_system.AddConstraint(constraint);
