### Кэширование в памяти

```cpp
class MeshCache {
    std::unordered_map<MeshID, MeshComponent> cache;

    const MeshComponent& getOrLoad(MeshID id) {
        if (cache.contains(id)) return cache[id];

        MeshComponent mesh = loadAndOptimize(id);
        cache[id] = mesh;
        return cache[id];
    }
};
