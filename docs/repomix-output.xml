    SoundPool m_digPool;
    SoundPool m_placePool;
    SoundPool m_stepPool;
    SoundPool m_breakPool;

    bool isAudible(const glm::vec3& pos) {
        return glm::length(pos - m_listenerPos) < 64.0f;
    }

    glm::vec3 m_listenerPos;
};
