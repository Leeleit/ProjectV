{
    float3 getCenter();
    float getRadius();
    bool contains(float3 point);
};
```

### Реализация интерфейса

```slang
struct Sphere : IShape
{
    float3 center;
    float radius;

    float3 getCenter() { return center; }
    float getRadius() { return radius; }

    bool contains(float3 point)
    {
        return length(point - center) <= radius;
    }
};
```

