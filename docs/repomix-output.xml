void csMain(uint3 id : SV_DispatchThreadID) { }

// Принудительный инлайнинг
[ForceInline]
float fastFunction(float x) { return x * 2.0; }

// Запрет инлайнинга
[NoInline]
float complexFunction(float x) { /* ... */ }

// Оптимизация для кэша
[OptimizeForCache]
struct PackedData { /* ... */ };
```

