    state->mainWindow = SDL_CreateWindow(
        "Main Window", 1280, 720,
        SDL_WINDOW_VULKAN | SDL_WINDOW_RESIZABLE
    );

    state->toolWindow = SDL_CreateWindow(
        "Tools", 300, 600,
