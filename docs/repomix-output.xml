## Структуры

### Объявление структур

```slang
// Простая структура
struct Vertex
{
    float3 position;
    float3 normal;
    float2 uv;
};

// Структура с методами
struct Transform
{
    float4x4 matrix;

    float3 transformPoint(float3 p)
    {
        return mul(matrix, float4(p, 1.0)).xyz;
    }

    float3 transformDirection(float3 d)
    {
        return mul(matrix, float4(d, 0.0)).xyz;
    }
};
