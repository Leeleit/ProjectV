{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "ninja.exe",
        "CMAKE_CXX_STANDARD": "26",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang-CL Debug",
      "inherits": "base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_CXX_FLAGS": "/clang:-fuse-ld=lld-link /EHsc /W4 /WX",
        "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld-link",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [
            "Windows"
          ]
        }
      }
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows Clang-CL Release",
      "inherits": "windows-clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "/clang:-fuse-ld=lld-link /EHsc /O2"
      }
    }
  ]
}
